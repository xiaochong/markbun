{
	"name": "pingwrite",
	"version": "0.1.0",
	"description": "A fast, beautiful, Typora-like markdown desktop editor built with Electrobun and Milkdown",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage"
	},
	"dependencies": {
		"@milkdown/crepe": "^7.19.0",
		"@milkdown/kit": "^7.19.0",
		"@milkdown/plugin-clipboard": "^7.19.0",
		"@milkdown/plugin-history": "^7.19.0",
		"@milkdown/react": "^7.19.0",
		"@milkdown/theme-nord": "^7.19.0",
		"clsx": "^2.1.1",
		"electrobun": "1.15.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.18",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}

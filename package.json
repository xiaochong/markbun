{
	"name": "markbun",
	"version": "0.3.0",
	"description": "A fast, beautiful, Typora-like markdown desktop editor built with Electrobun and Milkdown (Mark + Bun)",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary && bun scripts/post-build.ts",
		"build:stable": "vite build && electrobun build --env=stable && bun scripts/post-build.ts",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage",
		"typecheck": "bash scripts/typecheck.sh",
		"lint": "bun run typecheck && bun test"
	},
	"dependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language": "^6.12.2",
		"@codemirror/search": "^6.6.0",
		"@codemirror/state": "6.5.4",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "6.39.17",
		"@milkdown/crepe": "^7.19.0",
		"@milkdown/kit": "^7.19.0",
		"@milkdown/plugin-clipboard": "^7.19.0",
		"@milkdown/plugin-history": "^7.19.0",
		"@milkdown/react": "^7.19.0",
		"@milkdown/theme-nord": "^7.19.0",
		"@milkdown/utils": "^7.19.0",
		"clsx": "^2.1.1",
		"electrobun": "1.16.0",
		"html2canvas": "^1.4.1",
		"i18next": "^25.10.3",
		"marked": "^17.0.5",
		"mermaid": "^11.13.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-i18next": "^16.6.0",
		"remark-breaks": "^4.0.0",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.18",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	},
	"overrides": {
		"@codemirror/state": "6.5.4",
		"@codemirror/view": "6.39.17"
	}
}
